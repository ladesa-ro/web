{
  "name": "@ladesa-ro/web.api.client",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate-client": "openapi-ts && prettier --write ./src/__generated__"
  },
  "nx": {
    "targets": {
      "generate-client": {
        "cache": true,
        "inputs": [
          "{projectRoot}/openapi-ts.config.mts"
        ],
        "outputs": [
          "{projectRoot}/src/__generated__"
        ]
      }
    }
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.94.5",
    "typescript": "5.9.3"
  }
}
